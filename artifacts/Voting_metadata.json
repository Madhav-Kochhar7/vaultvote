				}
			},
			"kind": "dev",
			"methods": {
				"addCandidate(string)": {
					"details": "Only the contract owner (deployer) can call this. Cannot be called      while the election is open to ensure a fair ballot.",
					"params": {
						"_name": "The display name of the candidate."
					}
				},
				"closeElection()": {
					"details": "Only the owner can close the election."
				},
				"constructor": {
					"details": "Sets the original contract deployer as the owner via Ownable.      The election starts CLOSED — owner must call openElection() first."
				},
				"getAllCandidates()": {
					"details": "The frontend loops over these arrays to build the candidate cards.",
					"returns": {
						"ids": "       Array of candidate IDs.",
						"names": "     Array of candidate names.",
						"voteCounts": "Array of vote counts."
					}
				},
				"openElection()": {
					"details": "Only the owner can open the election. Requires at least one candidate."
				},
				"owner()": {
					"details": "Returns the address of the current owner."
				},
				"renounceOwnership()": {
					"details": "Leaves the contract without owner. It will not be possible to call `onlyOwner` functions. Can only be called by the current owner. NOTE: Renouncing ownership will leave the contract without an owner, thereby disabling any functionality that is only available to the owner."
				},
				"transferOwnership(address)": {
					"details": "Transfers ownership of the contract to a new account (`newOwner`). Can only be called by the current owner."
				},
				"vote(uint256)": {
					"details": "Uses `msg.sender` to identify the voter. Enforces:      1. The election must be open.      2. The candidate must exist.      3. The voter must not have voted before (one-person-one-vote).",
					"params": {
						"_candidateId": "The ID of the candidate to vote for."
					}
				}
			},
			"title": "Voting",
			"version": 1
		},
		"userdoc": {
			"events": {
				"CandidateAdded(uint256,string)": {
					"notice": "Emitted when a new candidate is added by the owner."
				},
				"ElectionStatusChanged(bool)": {
					"notice": "Emitted when the owner opens or closes the election."
				},
				"Voted(address,uint256)": {
					"notice": "Emitted when a voter successfully casts their vote."
				}
			},
			"kind": "user",
			"methods": {
				"addCandidate(string)": {
					"notice": "Adds a new candidate to the election."
				},
				"candidateCount()": {
					"notice": "Total number of candidates added. Also serves as the ID counter."
				},
				"candidates(uint256)": {
					"notice": "Maps candidate IDs to their Candidate struct."
				},
				"closeElection()": {
					"notice": "Closes the election, preventing further votes."
				},
				"electionOpen()": {
					"notice": "Whether the election is currently open for voting."
				},
				"getAllCandidates()": {
					"notice": "Returns all candidates and their vote tallies as parallel arrays."
				},
				"getTotalVotes()": {
					"notice": "Returns the total number of votes cast across all candidates."
				},
				"hasVoted(address)": {
					"notice": "Tracks whether an address has already voted. Enforces one-person-one-vote."
				},
				"openElection()": {
					"notice": "Opens the election so voters can start casting votes."
				},
				"vote(uint256)": {
					"notice": "Casts a vote for a specific candidate."
				}
